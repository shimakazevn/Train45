PhantomCameraManager="*res://addons/phantom_camera/scripts/managers/phantom_camera_manager.gd"
SoundManager="*res://Autoloads/sound_manager.tscn"
CutSceneManager="*res://Autoloads/cut_scene_manager.tscn"
BugReporter="res://Autoloads/BugReporter.gd"
Dialogic="*res://addons/dialogic/Core/DialogicGameHandler.gd"
LightOptimizer="*res://Autoloads/LightOptimizer.gd"
DialogicDubbingManager="*res://Autoloads/dialogic_dubbing_manager.gd"
SteamManager="*res://Autoloads/SteamManager.gd"
AchievementManager="*res://Autoloads/AchievementManager.gd"
MobileControls="*res://Autoloads/MobileControls.gd"
QABot="*res://Autoloads/QABot.gd"

