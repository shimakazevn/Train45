; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Train45"
config/version="1.0.2"
run/main_scene="res://Gameplay/main_menu.tscn"
config/use_custom_user_dir=true
config/custom_user_dir_name="TrainNumber45"
config/features=PackedStringArray("4.5", "Forward Plus")
run/max_fps=60
boot_splash/fullsize=false
boot_splash/use_filter=false
boot_splash/image="uid://d210rjjd00xbo"
config/icon="uid://d210rjjd00xbo"
config/windows_native_icon="res://train45_icon.ico"

[autoload]

LanguageManager="*res://Autoloads/LanguageManager.gd"
ConfigFileHandler="*res://Autoloads/ConfigFileHandler.gd"
MetaProgression="*res://Autoloads/meta_progression.tscn"
